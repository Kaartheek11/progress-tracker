# Public VAPID key from `npm run vapid:generate`.
VITE_PUSH_REMINDER_PUBLIC_KEY=

# Cloudflare Worker endpoint that stores Push API subscriptions and reminder preferences.
# Example: https://momentum-reminders.<account>.workers.dev/subscribe
VITE_PUSH_REMINDER_SUBSCRIBE_URL=

# Optional Cloudflare Worker endpoint that removes Push API subscriptions.
# Example: https://momentum-reminders.<account>.workers.dev/unsubscribe
VITE_PUSH_REMINDER_UNSUBSCRIBE_URL=
